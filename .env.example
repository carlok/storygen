# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@yourdomain.com

# ── Multi-user mode ───────────────────────────────────────────────────────────
# Remove the leading # from each line to enable multi-user mode.
#
# 1. Generate a secret key (run once):
#    python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=change-me-to-a-64-char-hex-string

# 2. Google OAuth2 — see README "Google OAuth2 setup" for step-by-step.
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# 3. Redirect URI — must match exactly what you registered in Google Cloud.
#    Default works for local dev; override for production.
# OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# 4. PostgreSQL connection string.
# DATABASE_URL=postgresql+asyncpg://storygen:yourpassword@db/storygen
# POSTGRES_PASSWORD=yourpassword

# 5. First-admin email — this account is promoted to admin on first login.
# ADMIN_EMAIL=you@yourdomain.com

# ── Cookie security ───────────────────────────────────────────────────────────
# Defaults to "true" (requires HTTPS). Set to "false" only for local HTTP dev.
# SECURE_COOKIES=false
