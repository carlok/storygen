# ── Required: secret key ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-hex-string

# ── Google OAuth2 — see README "Google OAuth2 setup" for step-by-step ─────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# Redirect URI — must match exactly what you registered in Google Cloud.
# Default works for local dev; override for production.
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://storygen:yourpassword@db/storygen
POSTGRES_PASSWORD=yourpassword

# ── First-admin email (promoted to admin on first login) ──────────────────────
ADMIN_EMAIL=you@yourdomain.com

# ── SMTP (stdlib smtplib, port 587 STARTTLS) ──────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASSWORD=yoursmtppassword
SMTP_FROM=noreply@yourdomain.com

# ── Limits ────────────────────────────────────────────────────────────────────
DAILY_VIDEO_LIMIT=3

# ── Cookie security ───────────────────────────────────────────────────────────
# Defaults to "true" (requires HTTPS). Set to "false" only for local HTTP dev.
# SECURE_COOKIES=false
